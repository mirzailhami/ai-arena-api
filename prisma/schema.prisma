generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Problem {
  id             String   @id @default(uuid())
  problemName    String
  zipFileName    String
  description    String?
  status         String   @default("Pending Test")
  isContestReady Boolean  @default(false)
  isTested       Boolean  @default(false)
  buildLog       String?
  uploadedAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("problems")
}

model Tournament {
  id                     String           @id @default(uuid())
  name                   String
  numRounds              Int
  initialEntrants        Int
  maxContestantsPerMatch Int
  advancingContestants   Int
  startDate              DateTime         @default(now())
  roundDurationMinutes   Int              @default(60)
  intermissionMinutes    Int              @default(15)
  isActive               Boolean          @default(true)
  status                 TournamentStatus @default(DRAFT)
  publishedAt            DateTime?
  bracketJson            Json
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  rooms Room[]

  @@map("tournaments")
}

enum TournamentStatus {
  DRAFT
  PUBLISHED
  IN_PROGRESS
  COMPLETED
}

enum RoomStatus {
  PENDING
  DEPLOYING
  RUNNING
  STOPPING
  STOPPED
  FAILED
}

model Room {
  id           String     @id @default(uuid())
  tournamentId String
  roundNumber  Int
  contestId    String
  roomName     String
  url          String?
  status       RoomStatus @default(PENDING)
  taskArn      String?
  scheduledAt  DateTime
  deployedAt   DateTime?
  expiresAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@map("rooms")
}
