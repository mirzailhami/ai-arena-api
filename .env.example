# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aiarena

# Server
PORT=3000
NODE_ENV=development

# Topcoder JWT validation
AUTH_SECRET=your-topcoder-jwt-secret-here
VALID_ISSUERS=https://api.topcoder-dev.com,https://topcoder-dev.auth0.com/

# Local filesystem storage for problem zip files
# Default: ./data/problems (relative to CWD)
PROBLEMS_ROOT=./data/problems

# Optional: path to synthetica2.war arena asset
# When set, the file is ADD'd into the Docker build context during problem test.
# When NOT set, the ADD instruction is silently omitted (build proceeds without it).
# Matches Part 1: ARENA_SYNTHETICA_WAR_PATH / arena.manager.synthetica.war.path
ARENA_SYNTHETICA_WAR_PATH=

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=https://local.topcoder-dev.com,http://localhost:3001
