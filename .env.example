# AI Arena API - Environment Configuration
# Copy this file to .env and fill in your values

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/ai_arena?schema=public

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Authentication (Topcoder Auth0 RS256 tokens)
# Public keys are fetched automatically from the JWKS endpoint — no secret needed.
JWKS_URI=https://auth.topcoder-dev.com/.well-known/jwks.json
VALID_ISSUERS=https://auth.topcoder-dev.com/
AUTH_SECRET=

# File Storage Paths
PROBLEMS_ROOT=./data/problems
# Optional: path to synthetica2.war arena asset used during problem testing
ARENA_SYNTHETICA_WAR_PATH=

# CORS Configuration (comma-separated allowed origins)
CORS_ORIGINS=https://local.topcoder-dev.com,http://localhost:4200,http://localhost:3000
